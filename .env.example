# ============================================
# AeroMind — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://aeromind:aeromind_secret@postgres:5432/aeromind
DATABASE_URL_SYNC=postgresql://aeromind:aeromind_secret@postgres:5432/aeromind
POSTGRES_USER=aeromind
POSTGRES_PASSWORD=aeromind_secret
POSTGRES_DB=aeromind

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- OpenSky Network API ----
# Create account at https://opensky-network.org
# Then create API client at https://opensky-network.org/my-opensky/account
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
# Leave empty to use anonymous access (400 credits/day, 10s resolution)

# ---- Aviation Weather Center ----
# Free, no key required
# https://aviationweather.gov/api/data

# ---- OpenWeatherMap ----
# Free tier: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ---- Cesium Ion ----
# Free community account: https://cesium.com/ion
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# ---- App Settings ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ---- ML Model ----
MODEL_PATH=ml_models/trained
